# ── Database (Vercel Postgres / Neon) ───────────────────────────
# Auto-injected when you create a Postgres store in the Vercel dashboard.
# Neon native integration sets DATABASE_URL; legacy Vercel Postgres sets POSTGRES_URL.
DATABASE_URL=

# ── File storage (Vercel Blob) ──────────────────────────────────
# Auto-injected when you create a Blob store in the Vercel dashboard.
BLOB_READ_WRITE_TOKEN=

# ── Admin login ─────────────────────────────────────────────────
# You set these yourself in the Vercel dashboard (and locally for dev).
ADMIN_USERNAME=
ADMIN_PASSWORD=
# Random 32+ character string used to sign the admin session cookie.
AUTH_SECRET=
